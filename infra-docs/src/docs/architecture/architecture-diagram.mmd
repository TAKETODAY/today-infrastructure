flowchart BT
    subgraph APP_LAYER["Application Layer"]
        APP["infra-app<br/>@InfraApplication, Bootstrap,<br/>Auto-Configuration, Health"]
        STARTERS["infra-starter-* (32 starters)<br/>Web / JDBC / Jackson / Logback / ..."]
    end

    subgraph WEB_LAYER["Web / HTTP Layer"]
        WMVC["infra-webmvc<br/>DispatcherHandler, MVC Pattern"]
        WREACT["infra-web-reactive<br/>Reactive Web"]
        WBSOCK["infra-websocket<br/>WebSocket Client / Server"]
        HTTP["infra-http<br/>HTTP Types, Client/Server<br/>Abstractions"]
        HTTPCLIENT["infra-http-client / infra-http-service<br/>HTTP Clients, Declarative HTTP"]
        WCONV["infra-http-converter<br/>JSON / XML Message Converters"]
        WCODE["infra-http-codec<br/>HTTP Codecs"]
        WSERV["infra-web-server<br/>WebServer Abstraction"]
        NETTY["infra-web-netty-server<br/>Netty HTTP Server"]
        REACTNETTY["infra-web-reactor-server<br/>Reactor Netty Server"]
    end

    subgraph DATA_LAYER["Data Layer"]
        PERSIST["infra-persistence<br/>Lightweight ORM<br/>@Table, @Column, EntityManager"]
        JDBC["infra-jdbc<br/>JDBC Abstraction<br/>Connection, Row, DataSource"]
        TX["infra-tx<br/>Transaction Management<br/>@Transactional, JTA"]
        OXM["infra-oxm<br/>Object / XML Mapping"]
        JCACHE["infra-jcache<br/>JCache (JSR-107)<br/>@Cacheable, @CacheEvict"]
        INTEGRATION["module/* (14 modules)<br/>Flyway / Jackson / Gson<br/>Mail / Docker Compose / ..."]
    end

    subgraph CTX_LAYER["Context / IoC Container"]
        CTX["infra-context<br/>ApplicationContext, Events,<br/>@Conditional (40+), Scheduling,<br/>Validation, JMX, JNDI, Scripting"]
        CTXIDX["infra-context-indexer<br/>Component Indexing"]
        CTXSUP["infra-context-support<br/>Cache Abstraction"]
    end

    subgraph BEAN_LAYER["Bean Container"]
        BEANS["infra-beans<br/>BeanFactory, DI,<br/>Bean Definitions,<br/>Property Accessors,<br/>Type Converters"]
    end

    subgraph AOP_LAYER["AOP Layer"]
        AOP["infra-aop<br/>JDK Dynamic Proxy<br/>CGLIB Bytecode Proxy<br/>Pointcuts, Interceptors<br/>@AspectJ Support"]
        ASPECTS["infra-aspects<br/>AspectJ Aspects"]
    end

    subgraph CORE_LAYER["Core / Foundation"]
        CORE["infra-core<br/>- ASM Bytecode (Fork/Repackaged)<br/>- Annotation Engine (MergedAnnotations)<br/>- Type Conversion System<br/>- Environment / Properties<br/>- Resource Loading<br/>- AOT / RuntimeHints<br/>- Logging Abstraction<br/>- SSL / TLS<br/>- Codecs, Serialization<br/>- Utilities (lang/util)"]
        EXPR["infra-expression<br/>SpEL Expression Language"]
        INSTR["infra-instrument<br/>Load-Time Weaving Agent"]
    end

    subgraph TOOL_LAYER["Build / Tooling / Testing"]
        BUILD["infra-build/* (8 modules)<br/>Gradle Plugin, Maven Plugin<br/>Annotation Processors<br/>App Loader, Layered JAR"]
        BOM["infra-bom<br/>infra-dependencies<br/>BOM and Dependency Mgmt"]
        TEST["infra-test<br/>infra-test-support<br/>infra-testcontainers<br/>Test Utilities"]
    end

    subgraph JDK_LAYER["JDK Support"]
        JDK17["JDK 17 (Baseline)"]
        JDK21["JDK 21 (Virtual Threads)"]
        JDK24["JDK 24 (Multi-Release JAR)"]
    end

    JDK17 --> JDK21
    JDK21 --> JDK24
    JDK24 -.-> CORE
    JDK24 -.-> BEANS
    JDK24 -.-> CTX
    JDK24 -.-> APP

    CORE --> EXPR
    CORE --> INSTR
    CORE --> BEANS
    CORE --> AOP

    BEANS --> CTX
    AOP --> CTX

    CTX --> JDBC
    CTX --> TX
    CTX --> PERSIST
    CTX --> JCACHE
    CTX --> OXM
    CTX --> INTEGRATION

    CTX --> HTTP
    CTX --> WSERV
    WSERV --> NETTY
    WSERV --> REACTNETTY
    HTTP --> WCODE
    HTTP --> WCONV
    HTTP --> HTTPCLIENT

    HTTP --> WMVC
    HTTP --> WREACT
    HTTP --> WBSOCK

    WMVC --> APP
    WREACT --> APP
    WBSOCK --> APP
    HTTPCLIENT --> APP
    INTEGRATION --> APP
    PERSIST --> APP
    TX --> APP
    JCACHE --> APP

    APP --> STARTERS
    BUILD -.-> STARTERS
    TEST -.-> APP
    BOM -.-> STARTERS

